{
  "manifest_version": 3,
  "name": "Drive Photo Classifier",
  "version": "1.2.0",
  "version_name": "1.2.0 (Smart Photo Organiser)",
  "key": "",
  "description": "Organise Google Drive photos into Animals, Groups, Human and Junk using on-device AI. Your photos are never shared with any server.",
  "permissions": [
    "identity",
    "storage",
    "offscreen",
    "alarms",
    "notifications",
    "sidePanel"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://lh3.googleusercontent.com/*",
    "https://photos.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://photos.google.com/*"],
      "js": ["content/gp-relay.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://photos.google.com/*"],
      "js": ["content/gp-scraper.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "oauth2": {
    "client_id": "738149231002-ob7ebh8dmpae14l8ljsmkkcl84er0r27.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive",
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/drive.metadata.readonly"
    ]
  },
  "action": {
    "default_title": "Drive Photo Classifier"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "offscreen/*",
        "model_files/*",
        "src/face-db.js",
        "lib/ort/*.js",
        "lib/ort/*.wasm",
        "lib/ort/*.mjs"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
